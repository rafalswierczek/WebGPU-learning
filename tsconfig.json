{
    "compilerOptions": {
        "rootDir": "./src/ts/",
        "outDir": "./public/build/",
        "target": "ES2020",
        "lib": ["ES2020", "DOM"], // This is to prevent lib.dom.d.ts from being used as a type documentation. @webgpu/types is used instead.
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "types": [
            "@webgpu/types"
        ]
    },
    "exclude": [
        "node_modules"
    ],
    "$schema": "https://json.schemastore.org/tsconfig",
    "display": "Recommended"
}
